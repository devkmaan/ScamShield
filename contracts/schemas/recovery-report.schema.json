{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scamshield.local/schemas/recovery-report.schema.json",
  "title": "RecoveryReport",
  "type": "object",
  "required": ["reportId", "status", "summary", "checklist", "officialHelp", "createdAt"],
  "properties": {
    "reportId": { "type": "string" },
    "userId": { "type": "string" },
    "decisionId": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "checklist": {
      "type": "array",
      "items": { "type": "string" }
    },
    "officialHelp": {
      "type": "array",
      "items": { "type": "string" }
    },
    "createdAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}

